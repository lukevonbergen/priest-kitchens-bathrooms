---
---
<section class="relative overflow-hidden">
  <div class="grid grid-cols-1 lg:grid-cols-2">

    <div class="relative min-h-[280px] lg:min-h-[360px] overflow-hidden">
      <img
        src="/images/unnamed%20(11).jpg"
        alt="Priests Kitchens & Bathrooms — project in progress"
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gray-900/70"></div>
      <div class="relative z-10 h-full flex items-center p-12">
        <div class="text-white">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xs font-bold uppercase tracking-[0.18em] text-gray-300">HIGH WYCOMBE & BUCKINGHAMSHIRE</span>
          </div>
          <h3 class="text-2xl lg:text-3xl font-extrabold leading-tight">
            Kitchen &amp; Bathroom<br />Installers at Your Service
          </h3>
        </div>
      </div>
    </div>

    <div class="bg-[#0D1524] p-10 lg:p-14 flex flex-col justify-center">
      <h2 class="text-2xl lg:text-3xl font-extrabold text-white leading-tight mb-2">
        Request a Free Quote
      </h2>
      <p class="text-gray-400 text-[15px] mb-8">
        Tell us what you need and we'll get back to you promptly.
      </p>
      <form class="flex flex-col gap-3" onsubmit="return false;">
        <input
          type="text"
          placeholder="Your Name"
          class="w-full px-5 py-4 text-sm text-gray-900 bg-white rounded outline-none placeholder:text-gray-400"
        />
        <input
          type="tel"
          placeholder="Phone Number"
          class="w-full px-5 py-4 text-sm text-gray-900 bg-white rounded outline-none placeholder:text-gray-400"
        />
        <select class="w-full px-5 py-4 text-sm text-gray-900 bg-white rounded outline-none appearance-none">
          <option value="" disabled selected>What do you need?</option>
          <option>Kitchen Installation</option>
          <option>Bathroom Renovation</option>
          <option>Plumbing</option>
          <option>Tiling</option>
          <option>Electrical Work</option>
          <option>Carpentry</option>
          <option>Heating</option>
          <option>Plastering</option>
          <option>Other</option>
        </select>
        <button type="submit" class="w-full bg-[#6ec4d0] text-gray-900 px-6 py-4 text-xs font-bold uppercase tracking-wider rounded hover:bg-[#5aabb7] transition-colors mt-1">
          Request Quote
        </button>
      </form>
    </div>

  </div>
</section>
