---
const topLinks = ['About Us', 'Our Services', 'Contact Us'];
const services = [
  'Kitchen Installation', 'Bathroom Renovation', 'Plumbing',
  'Tiling', 'Electrical Work', 'Carpentry', 'Heating', 'Plastering',
];
const areas = ['High Wycombe', 'Beaconsfield', 'Maidenhead', 'Hazlemere', 'Marlow', 'Amersham', 'Aylesbury'];
---

<footer class="bg-[#0D1524] text-gray-400 pt-16 pb-6">
  <div class="max-w-7xl mx-auto px-6">

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-4">
          <img src="/priestkblogo.webp" alt="Priests Kitchens & Bathrooms" class="h-10 w-auto" />
        </a>
        <p class="text-sm leading-relaxed text-gray-400 mb-6">
          Priests Kitchens &amp; Bathrooms — designing and installing kitchens and bathrooms across High Wycombe and Buckinghamshire for over 20 years. Rated 9.9/10 on Checkatrade.
        </p>
      </div>

      <div>
        <h4 class="text-white font-bold text-sm uppercase tracking-widest mb-5">Quick Links</h4>
        <ul class="space-y-2.5">
          {topLinks.map(link => (
            <li><a href="#" class="text-gray-400 text-sm hover:text-white transition-colors">{link}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-white font-bold text-sm uppercase tracking-widest mb-5">Our Services</h4>
        <ul class="space-y-2.5">
          {services.map(service => (
            <li><a href="/service" class="text-gray-400 text-sm hover:text-white transition-colors">{service}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-white font-bold text-sm uppercase tracking-widest mb-5">Contact Us</h4>
        <ul class="space-y-4 mb-6">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-[#6ec4d0] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span class="text-sm">High Wycombe, Buckinghamshire</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-[#6ec4d0] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href="tel:07740272373" class="text-sm hover:text-white transition-colors">07740 272373</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-[#6ec4d0] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href="mailto:preists.k.b@gmail.com" class="text-sm hover:text-white transition-colors">preists.k.b@gmail.com</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-[#6ec4d0] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
            </svg>
            <span class="text-sm">9.9/10 on Checkatrade · 148 reviews</span>
          </li>
        </ul>
        <h5 class="text-white font-bold text-xs uppercase tracking-widest mb-3">Areas We Cover</h5>
        <div class="flex flex-wrap gap-1.5">
          {areas.map(area => (
            <span class="text-xs text-gray-400 bg-gray-800 rounded px-2 py-1">{area}</span>
          ))}
        </div>
      </div>

    </div>

    <div class="border-t border-gray-800 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-gray-600">
      <p>Copyright &copy;{new Date().getFullYear()} Priests Kitchens &amp; Bathrooms. All Rights Reserved.</p>
    </div>

  </div>
</footer>
