---
const posts = [
  {
    author: "Ashton's Team",
    date: '14', month: 'May',
    category: 'Boilers',
    title: 'The Benefits of Upgrading to a New Energy-Efficient Boiler',
    img: '/images/unnamed%20(12).webp',
    alt: 'Old boiler ready for replacement',
  },
  {
    author: "Ashton's Team",
    date: '08', month: 'May',
    category: 'Heating',
    title: "Signs Your Boiler Needs a Service — Don't Wait Until It's Too Late",
    img: '/images/unnamed%20(1).webp',
    alt: 'Corroded boiler burner showing need for service',
  },
  {
    author: "Ashton's Team",
    date: '02', month: 'May',
    category: 'Smart Home',
    title: 'How Smart Heating Controls Can Save You £150 a Year',
    img: '/images/unnamed%20(14).webp',
    alt: 'Vaillant boiler open during service inspection',
  },
];
---

<section class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-14">
      <div class="flex items-center justify-center gap-2 mb-4">
        <svg class="w-5 h-6 text-blue-600" viewBox="0 0 20 28" fill="currentColor">
          <path d="M10 0C7 5 2 9 2 16a8 8 0 0016 0C18 9 13 5 10 0z"/>
          <path d="M10 9c1 2.5 4 5 4 8a4 4 0 01-8 0c0-3 3-5.5 4-8z" fill="white" opacity="0.5"/>
        </svg>
        <span class="text-xs font-bold uppercase tracking-[0.18em] text-gray-500">BLOG &amp; NEWS</span>
      </div>
      <h2 class="text-3xl lg:text-4xl font-extrabold text-gray-900">The Heating Resource Centre</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {posts.map(post => (
        <article class="group cursor-pointer">
          <div class="relative aspect-[4/3] rounded-xl overflow-hidden mb-5">
            <img src={post.img} alt={post.alt} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            <div class="absolute bottom-3 left-3 flex items-center gap-2 bg-white rounded-full pl-1 pr-3 py-1">
              <div class="w-6 h-6 rounded-full bg-blue-100 flex items-center justify-center">
                <svg class="w-3 h-3 text-blue-600" viewBox="0 0 20 28" fill="currentColor"><path d="M10 0C7 5 2 9 2 16a8 8 0 0016 0C18 9 13 5 10 0z"/></svg>
              </div>
              <span class="text-xs font-semibold text-gray-700">{post.author}</span>
            </div>
            <div class="absolute top-3 right-3 bg-blue-600 text-white text-center rounded-md px-2 py-1.5 min-w-[40px]">
              <p class="text-lg font-extrabold leading-none">{post.date}</p>
              <p class="text-[9px] uppercase tracking-wider">{post.month}</p>
            </div>
          </div>
          <div class="flex items-center gap-2 mb-2">
            <span class="text-xs font-bold text-amber-500 uppercase tracking-wider">{post.category}</span>
          </div>
          <h3 class="font-bold text-gray-900 text-base leading-snug mb-4 group-hover:text-blue-600 transition-colors">{post.title}</h3>
          <a href="/blog" class="inline-flex items-center gap-1 text-xs font-bold uppercase tracking-wider text-gray-700 hover:text-blue-600 transition-colors">
            READ MORE
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
