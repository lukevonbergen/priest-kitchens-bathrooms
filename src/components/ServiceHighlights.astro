---
const highlights = [
  {
    title: 'Kitchen Installation',
    desc: 'Full design-to-finish kitchen fitting — units, worktops, appliances, plumbing and electrics.',
    featured: false,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" stroke-width="1.5"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9h18M9 21V9"/></svg>`,
  },
  {
    title: 'Bathroom Renovation',
    desc: 'Complete strip-out and refit. Plumbing, tiling, electrics and plastering — all done in-house.',
    featured: true,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 12h16M4 12a4 4 0 01-4-4V6a2 2 0 012-2h16a2 2 0 012 2v2a4 4 0 01-4 4M4 12v4a4 4 0 004 4h8a4 4 0 004-4v-4"/></svg>`,
  },
  {
    title: 'All Trades In-House',
    desc: 'Plumbing, tiling, electrical, carpentry, heating and plastering. One team, no subcontractors.',
    featured: false,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
  },
];
---

<section class="relative z-10 -mt-2 pb-0">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-0 shadow-xl">
      {highlights.map((item, i) => (
        <div class={`bg-white p-7 flex items-start gap-4 ${i < highlights.length - 1 ? 'border-b md:border-b-0 md:border-r border-gray-100' : ''}`}>
          <div class={`w-12 h-12 rounded-full flex-shrink-0 flex items-center justify-center ${item.featured ? 'bg-[#6ec4d0] text-gray-900' : 'bg-gray-100 text-gray-700'}`}>
            <Fragment set:html={item.icon} />
          </div>
          <div>
            <h3 class="font-bold text-gray-900 mb-1.5 text-base">{item.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
