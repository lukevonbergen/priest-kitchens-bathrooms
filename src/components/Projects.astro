---
---

<section class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex items-end justify-between mb-10">
      <span class="text-xs font-bold uppercase tracking-[0.18em] text-gray-500">RECENT PROJECTS</span>
      <span class="text-xs text-gray-400">High Wycombe &amp; Buckinghamshire</span>
    </div>

    <div class="projects-grid">
      <div class="p1 overflow-hidden rounded-lg">
        <img src="/images/unnamed%20(3).jpg" alt="Priests — kitchen installation" class="w-full h-full object-cover" loading="lazy" />
      </div>
      <div class="p2 overflow-hidden rounded-lg">
        <img src="/images/unnamed%20(15).jpg" alt="Priests — bathroom renovation" class="w-full h-full object-cover" loading="lazy" />
      </div>
      <div class="p3 overflow-hidden rounded-lg">
        <img src="/images/unnamed%20(8).jpg" alt="Priests — tiling work" class="w-full h-full object-cover" loading="lazy" />
      </div>
      <div class="p4 overflow-hidden rounded-lg">
        <img src="/images/unnamed%20(1).jpg" alt="Priests — finished kitchen" class="w-full h-full object-cover" loading="lazy" />
      </div>
      <div class="p5 overflow-hidden rounded-lg">
        <img src="/images/unnamed%20(2).jpg" alt="Priests — plumbing installation" class="w-full h-full object-cover" loading="lazy" />
      </div>
      <div class="p6 overflow-hidden rounded-lg">
        <img src="/images/unnamed%20(9).jpg" alt="Priests — completed bathroom" class="w-full h-full object-cover" loading="lazy" />
      </div>
      <div class="p7 overflow-hidden rounded-lg">
        <img src="/images/unnamed%20(4).jpg" alt="Priests — carpentry work" class="w-full h-full object-cover" loading="lazy" />
      </div>
      <div class="p8 overflow-hidden rounded-lg">
        <img src="/images/unnamed%20(5).jpg" alt="Priests — finished project" class="w-full h-full object-cover" loading="lazy" />
      </div>
    </div>
  </div>
</section>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: 220px 220px 180px;
    gap: 0.75rem;
  }
  .p1 { grid-column: 1; grid-row: 1 / 3; }
  .p2 { grid-column: 2; grid-row: 1; }
  .p3 { grid-column: 3; grid-row: 1; }
  .p4 { grid-column: 2; grid-row: 2; }
  .p5 { grid-column: 3; grid-row: 2; }
  .p6 { grid-column: 4; grid-row: 1 / 3; }
  .p7 { grid-column: 1 / 3; grid-row: 3; }
  .p8 { grid-column: 3 / 5; grid-row: 3; }

  @media (max-width: 767px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(4, 160px);
    }
    .p1, .p2, .p3, .p4, .p5, .p6, .p7, .p8 {
      grid-column: auto;
      grid-row: auto;
    }
  }
</style>
