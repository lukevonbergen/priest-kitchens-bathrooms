---
const quotes = [
  {
    rating: 5,
    quote: "I had a leak coming from the pipes under the kitchen sink. The workers from this company was very polite and friendly. They attended my property when they said they would and I was very happy with the work that they did. Their prices was also very reasonable.",
    name: 'Very Good kitchen Plumbers',
    location: 'September 2025',
  },
  {
    rating: 5,
    quote: "Very happy with the service I received from Mark at Priests Plumbing. Needed new washers and shower hose and shower head. Socket had to be secured back on the wall.",
    name: 'Shower was leaking from wall socket',
    location: 'June 2025',
  },
];
---

<section class="bg-[#0D1524] py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6">

    <div class="text-center mb-16">
      <span class="text-xs font-bold uppercase tracking-[0.18em] text-gray-500">WHAT CUSTOMERS SAY</span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 mb-14">
      {quotes.map(q => (
        <div class="relative">
          <div class="text-[#6ec4d0] text-8xl font-serif leading-none select-none mb-4" aria-hidden="true">"</div>
          <div class="flex gap-1 mb-5">
            {Array.from({ length: q.rating }).map(() => (
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>
          <p class="text-gray-200 text-lg lg:text-xl leading-relaxed font-light mb-8">
            {q.quote}
          </p>
          <div class="flex items-center gap-3">
            <div class="w-px h-8 bg-[#6ec4d0]"></div>
            <div>
              <p class="text-white font-bold text-sm">{q.name}</p>
              <p class="text-gray-500 text-xs">{q.location} · Checkatrade review</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="border-t border-gray-800 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-gray-500 text-sm">
        Rated <span class="text-white font-bold">9.9 out of 10</span> from 148 verified reviews on Checkatrade
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 border border-gray-700 text-gray-300 hover:text-white hover:border-gray-500 px-5 py-2.5 rounded text-xs font-bold uppercase tracking-widest transition-colors"
      >
        Get a Free Quote
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

  </div>
</section>
