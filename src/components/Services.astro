---
const featured = [
  {
    title: 'Kitchen Installation',
    desc: 'Full design-to-finish fitting — units, worktops, appliances, plumbing and electrics all handled in-house.',
    img: '/images/unnamed%20(4).jpg',
    alt: 'Priests Kitchens — kitchen installation project',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9h18M9 21V9"/></svg>`,
  },
  {
    title: 'Bathroom Renovation',
    desc: 'Complete strip-out and refit. Plumbing, tiling, electrics and plastering — one team, no subcontractors.',
    img: '/images/unnamed%20(13).jpg',
    alt: 'Priests Bathrooms — bathroom renovation project',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 12h16M4 12a4 4 0 01-4-4V6a2 2 0 012-2h16a2 2 0 012 2v2a4 4 0 01-4 4M4 12v4a4 4 0 004 4h8a4 4 0 004-4v-4"/></svg>`,
  },
];

const supporting = [
  {
    title: 'Plumbing',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 22c-4.97 0-9-2.24-9-5V7m18 0v10c0 2.76-4.03 5-9 5"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7c0-2.76 4.03-5 9-5s9 2.24 9 5"/></svg>`,
  },
  {
    title: 'Tiling',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="8" height="8" rx="1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><rect x="13" y="3" width="8" height="8" rx="1" stroke-width="1.5"/><rect x="3" y="13" width="8" height="8" rx="1" stroke-width="1.5"/><rect x="13" y="13" width="8" height="8" rx="1" stroke-width="1.5"/></svg>`,
  },
  {
    title: 'Electrical Work',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
  },
  {
    title: 'Carpentry & Plastering',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7l9-4 9 4v10l-9 4-9-4V7z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v18M3 7l9 4 9-4"/></svg>`,
  },
];
---

<section class="py-20 lg:py-28 bg-gray-50">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="flex items-end justify-between mb-10">
      <div>
        <span class="text-xs font-bold uppercase tracking-[0.18em] text-gray-500">OUR SERVICES</span>
        <h2 class="mt-3 text-3xl lg:text-4xl font-extrabold text-gray-900 leading-tight">
          Everything Your Project Needs<br />Under One Roof
        </h2>
      </div>
      <a href="/service" class="hidden md:inline-flex items-center gap-1.5 text-[#6ec4d0] text-xs font-bold uppercase tracking-wider hover:gap-2.5 transition-all">
        All Services
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Featured: Kitchen + Bathroom -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
      {featured.map(service => (
        <div class="relative rounded-xl overflow-hidden group" style="min-height: 340px;">
          <img
            src={service.img}
            alt={service.alt}
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-gray-900/90 via-gray-900/30 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-7">
            <div class="w-9 h-9 rounded-lg bg-[#6ec4d0] flex items-center justify-center mb-3 text-gray-900">
              <Fragment set:html={service.icon} />
            </div>
            <h3 class="text-xl font-extrabold text-white mb-1.5">{service.title}</h3>
            <p class="text-gray-300 text-sm leading-relaxed mb-4 max-w-xs">{service.desc}</p>
            <a href="/service" class="inline-flex items-center gap-1 text-[#6ec4d0] text-xs font-bold uppercase tracking-wider group-hover:gap-2 transition-all">
              Learn More
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Supporting trades — 4-col icon strip -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {supporting.map(service => (
        <div class="bg-white rounded-xl px-5 py-6 border border-gray-100 flex items-center gap-4">
          <div class="w-9 h-9 rounded-lg bg-gray-100 flex-shrink-0 flex items-center justify-center text-gray-600">
            <Fragment set:html={service.icon} />
          </div>
          <span class="font-bold text-gray-900 text-sm">{service.title}</span>
        </div>
      ))}
    </div>

  </div>
</section>
