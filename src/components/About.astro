---
const checkpoints = [
  'Over 20 years of kitchen and bathroom design and installation',
  'All trades in-house — plumbing, tiling, electrical, carpentry, heating and plastering',
  'Covering High Wycombe and the wider Buckinghamshire area',
];
---

<section class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Left: Images -->
      <div class="relative">
        <div class="flex gap-4 items-end">
          <div class="w-5/12 flex flex-col gap-4 pb-2">
            <div class="aspect-[3/4] rounded-lg overflow-hidden w-full">
              <img
                src="/images/unnamed%20(7).jpg"
                alt="Priests Kitchens & Bathrooms — installation work"
                class="w-full h-full object-cover"
              />
            </div>
            <div class="bg-gray-900 text-white p-4 rounded-lg text-center">
              <p class="text-3xl font-extrabold leading-none">20+</p>
              <p class="text-sm text-gray-300 mt-1">Years Of Experience</p>
            </div>
          </div>
          <div class="w-7/12">
            <div class="aspect-[3/4] rounded-lg overflow-hidden w-full">
              <img
                src="/images/unnamed%20(15).jpg"
                alt="Priests Kitchens & Bathrooms — finished project"
                class="w-full h-full object-cover"
              />
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Content -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <span class="text-xs font-bold uppercase tracking-[0.18em] text-gray-500">ABOUT US</span>
        </div>

        <h2 class="text-3xl lg:text-4xl font-extrabold text-gray-900 leading-tight mb-5">
          Over 20 Years Fitting Kitchens and Bathrooms Across Buckinghamshire
        </h2>

        <p class="text-gray-500 text-[15px] leading-relaxed mb-4">
          Priests Kitchens &amp; Bathrooms are a High Wycombe-based installation company with over 20 years of experience in kitchen and bathroom design and fitting. We handle every aspect of the job ourselves — no subcontractors, no gaps in communication.
        </p>
        <p class="text-gray-500 text-[15px] leading-relaxed mb-7">
          Our team covers all the trades required for a complete installation: plumbing, tiling, electrical work, carpentry, heating, and plastering. From the initial consultation to the final finish, one team handles the lot.
        </p>

        <ul class="space-y-3 mb-8">
          {checkpoints.map(point => (
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 rounded-full bg-[#6ec4d0] flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <span class="text-gray-700 font-semibold text-sm" set:html={point} />
            </li>
          ))}
        </ul>

        <a
          href="/about"
          class="inline-flex items-center gap-2 border-2 border-[#6ec4d0] text-[#6ec4d0] px-7 py-3.5 text-xs font-bold uppercase tracking-widest hover:bg-[#6ec4d0] hover:text-gray-900 transition-colors rounded"
        >
          READ MORE
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

    </div>
  </div>
</section>
