---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const areas = ['High Wycombe', 'Beaconsfield', 'Maidenhead', 'Hazlemere', 'Marlow', 'Amersham', 'Aylesbury'];
---

<Layout title="Contact — Priests Kitchens & Bathrooms" description="Get in touch with Priests Kitchens & Bathrooms. Based in High Wycombe, covering Buckinghamshire. Request a free quote for your kitchen or bathroom project.">
  <TopBar />
  <Navbar />

  <section class="bg-gray-50 border-b border-gray-100 py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-6">
      <span class="text-xs font-bold uppercase tracking-[0.18em] text-gray-500">Get In Touch</span>
      <h1 class="mt-3 text-4xl lg:text-5xl font-extrabold text-gray-900 leading-tight">Request a Free Quote</h1>
      <p class="mt-5 text-gray-500 text-[15px] leading-relaxed max-w-xl">
        Based in High Wycombe, covering Buckinghamshire. Send us a message and we'll get back to you promptly.
      </p>
    </div>
  </section>

  <section class="bg-white py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">

        <div>
          <div class="mb-10">
            <h2 class="text-xl font-extrabold text-gray-900 mb-6">Our Details</h2>
            <ul class="space-y-5">
              <li class="flex items-start gap-4">
                <span class="w-9 h-9 bg-[#eaf8fa] rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-[#6ec4d0]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </span>
                <div>
                  <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-0.5">Based In</p>
                  <a href="https://maps.google.com/?q=High+Wycombe,+Buckinghamshire" target="_blank" rel="noopener" class="text-gray-900 font-semibold hover:text-[#6ec4d0] transition-colors">High Wycombe, Buckinghamshire</a>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <span class="w-9 h-9 bg-[#eaf8fa] rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-[#6ec4d0]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </span>
                <div>
                  <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-0.5">Phone</p>
                  <a href="tel:07740272373" class="text-gray-900 font-semibold hover:text-[#6ec4d0] transition-colors">07740 272373</a>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <span class="w-9 h-9 bg-[#eaf8fa] rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-[#6ec4d0]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </span>
                <div>
                  <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-0.5">Email</p>
                  <a href="mailto:priests.k.b@gmail.com" class="text-gray-900 font-semibold hover:text-[#6ec4d0] transition-colors">priests.k.b@gmail.com</a>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <span class="w-9 h-9 bg-[#eaf8fa] rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-yellow-500" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                </span>
                <div>
                  <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-0.5">Checkatrade Rating</p>
                  <span class="text-gray-900 font-semibold">9.9/10 from 148 verified reviews</span>
                </div>
              </li>
            </ul>
          </div>

          <div class="mb-10">
            <h2 class="text-xl font-extrabold text-gray-900 mb-4">Areas We Cover</h2>
            <p class="text-gray-500 text-sm mb-4">We work across High Wycombe and the surrounding towns. Not sure if we cover your area? Just ask.</p>
            <div class="flex flex-wrap gap-2">
              {areas.map(area => (
                <span class="text-sm text-gray-600 bg-gray-100 rounded px-3 py-1.5 font-medium">{area}</span>
              ))}
            </div>
          </div>

          <div class="bg-gray-50 rounded-xl p-6 border border-gray-100">
            <h3 class="font-extrabold text-gray-900 text-base mb-3">What happens next?</h3>
            <ol class="space-y-2 text-sm text-gray-500">
              <li class="flex gap-3"><span class="font-bold text-[#6ec4d0] flex-shrink-0">1.</span> We review your message and get back to you within one business day.</li>
              <li class="flex gap-3"><span class="font-bold text-[#6ec4d0] flex-shrink-0">2.</span> We'll arrange a visit to see the space and understand exactly what you need.</li>
              <li class="flex gap-3"><span class="font-bold text-[#6ec4d0] flex-shrink-0">3.</span> You receive a clear, itemised quote with no hidden costs.</li>
            </ol>
          </div>
        </div>

        <div>
          <h2 class="text-xl font-extrabold text-gray-900 mb-6">Send Us a Message</h2>
          <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-5">
            <div>
              <label class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-2">Name <span class="text-[#6ec4d0]">*</span></label>
              <div class="grid grid-cols-2 gap-3">
                <input type="text" name="first_name" placeholder="First" required class="w-full border border-gray-200 rounded px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-[#6ec4d0] transition-colors" />
                <input type="text" name="last_name" placeholder="Last" required class="w-full border border-gray-200 rounded px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-[#6ec4d0] transition-colors" />
              </div>
            </div>
            <div>
              <label class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-2">Email <span class="text-[#6ec4d0]">*</span></label>
              <input type="email" name="email" placeholder="your@email.com" required class="w-full border border-gray-200 rounded px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-[#6ec4d0] transition-colors" />
            </div>
            <div>
              <label class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-2">Phone <span class="text-[#6ec4d0]">*</span></label>
              <input type="tel" name="phone" placeholder="07740 272373" required class="w-full border border-gray-200 rounded px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-[#6ec4d0] transition-colors" />
            </div>
            <div>
              <label class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-2">Your Location <span class="text-[#6ec4d0]">*</span></label>
              <input type="text" name="location" placeholder="e.g. High Wycombe, Marlow" required class="w-full border border-gray-200 rounded px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-[#6ec4d0] transition-colors" />
            </div>
            <div>
              <label class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-2">What do you need? <span class="text-[#6ec4d0]">*</span></label>
              <select name="service" required class="w-full border border-gray-200 rounded px-4 py-3 text-sm text-gray-900 focus:outline-none focus:border-[#6ec4d0] transition-colors appearance-none">
                <option value="" disabled selected>Select a service</option>
                <option>Kitchen Installation</option>
                <option>Bathroom Renovation</option>
                <option>Plumbing</option>
                <option>Tiling</option>
                <option>Electrical Work</option>
                <option>Carpentry</option>
                <option>Heating</option>
                <option>Plastering</option>
                <option>Multiple services / full project</option>
                <option>Other</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-2">Tell Us More</label>
              <textarea name="message" rows="4" placeholder="Describe your project — size, scope, timescales..." class="w-full border border-gray-200 rounded px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-[#6ec4d0] transition-colors resize-none"></textarea>
            </div>
            <button type="submit" class="w-full bg-[#6ec4d0] text-gray-900 px-6 py-4 text-xs font-bold uppercase tracking-widest hover:bg-[#5aabb7] transition-colors rounded">
              Send Message
            </button>
            <p class="text-xs text-gray-400"><span class="text-[#6ec4d0]">*</span> Required fields. We'll get back to you within one business day.</p>
          </form>
        </div>

      </div>
    </div>
  </section>

  <section class="bg-[#0D1524] py-14">
    <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <h2 class="text-2xl font-extrabold text-white">Planning a kitchen or bathroom project?</h2>
        <p class="text-gray-400 text-sm mt-1">Get in touch — we'll come out, take a look, and give you a straight quote.</p>
      </div>
      <a
        href="#"
        onclick="window.scrollTo({top: 0, behavior: 'smooth'}); return false;"
        class="inline-flex items-center gap-2 bg-[#6ec4d0] text-gray-900 px-7 py-4 text-xs font-bold uppercase tracking-widest hover:bg-[#5aabb7] transition-colors rounded whitespace-nowrap"
      >
        BACK TO FORM
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 15l7-7 7 7"/>
        </svg>
      </a>
    </div>
  </section>

  <Footer />
</Layout>
