---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About Us — Priests Kitchens & Bathrooms" description="Over 20 years designing and installing kitchens and bathrooms in High Wycombe and across Buckinghamshire. All trades handled in-house. Rated 9.9/10 on Checkatrade.">
  <TopBar />
  <Navbar />

  <section class="bg-gray-50 border-b border-gray-100 py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-6">
      <span class="text-xs font-bold uppercase tracking-[0.18em] text-gray-500">About Us</span>
      <h1 class="mt-3 text-4xl lg:text-5xl font-extrabold text-gray-900 leading-tight">
        Over 20 Years Fitting Kitchens<br />and Bathrooms Properly
      </h1>
    </div>
  </section>

  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="relative">
          <div class="flex gap-4 items-end">
            <div class="w-5/12 flex flex-col gap-4 pb-2">
              <div class="aspect-[3/4] rounded-lg overflow-hidden w-full">
                <img src="/images/unnamed%20(7).jpg" alt="Priests — kitchen installation" class="w-full h-full object-cover" />
              </div>
              <div class="bg-gray-900 text-white p-4 rounded-lg text-center">
                <p class="text-3xl font-extrabold leading-none">20+</p>
                <p class="text-sm text-gray-300 mt-1">Years Of Experience</p>
              </div>
            </div>
            <div class="w-7/12">
              <div class="aspect-[3/4] rounded-lg overflow-hidden w-full">
                <img src="/images/unnamed%20(15).jpg" alt="Priests — bathroom renovation" class="w-full h-full object-cover" />
              </div>
            </div>
          </div>
        </div>

        <div>
          <p class="text-gray-500 text-[15px] leading-relaxed mb-5">
            Priests Kitchens &amp; Bathrooms are a High Wycombe-based installation company with over 20 years of experience designing and fitting kitchens and bathrooms across Buckinghamshire. We've built our reputation on straight talking, clean work, and not leaving until the job's right.
          </p>
          <p class="text-gray-500 text-[15px] leading-relaxed mb-5">
            Our team covers all the trades required for a complete installation: plumbing, tiling, electrical work, carpentry, heating and plastering. You deal with one team from start to finish — no subcontractors, no miscommunication between trades.
          </p>
          <p class="text-gray-500 text-[15px] leading-relaxed mb-5">
            We're based in High Wycombe and work throughout Buckinghamshire, including Beaconsfield, Maidenhead, Marlow, Amersham, Hazlemere and Aylesbury.
          </p>
          <p class="text-gray-500 text-[15px] leading-relaxed">
            Whether you're planning a full kitchen remodel or a straightforward bathroom update, we take the same approach: listen to what you need, give you an honest quote, and deliver work you'll be happy with for years.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <div class="bg-white rounded-xl p-8 border border-gray-100">
          <div class="w-10 h-10 rounded-full bg-[#6ec4d0] flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="font-extrabold text-gray-900 text-lg mb-2">All Trades In-House</h3>
          <p class="text-gray-500 text-sm leading-relaxed">Plumbing, tiling, electrical, carpentry, heating and plastering — all handled by our own team. One point of contact for the whole job.</p>
        </div>

        <div class="bg-white rounded-xl p-8 border border-gray-100">
          <div class="w-10 h-10 rounded-full bg-[#6ec4d0] flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
            </svg>
          </div>
          <h3 class="font-extrabold text-gray-900 text-lg mb-2">9.9/10 on Checkatrade</h3>
          <p class="text-gray-500 text-sm leading-relaxed">Rated 9.9 out of 10 from 148 verified Checkatrade reviews. Our score reflects the standard we hold ourselves to on every single job.</p>
        </div>

        <div class="bg-white rounded-xl p-8 border border-gray-100">
          <div class="w-10 h-10 rounded-full bg-[#6ec4d0] flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="font-extrabold text-gray-900 text-lg mb-2">Local to High Wycombe</h3>
          <p class="text-gray-500 text-sm leading-relaxed">Based in High Wycombe, covering Beaconsfield, Maidenhead, Marlow, Amersham, Hazlemere, Aylesbury and surrounding areas.</p>
        </div>

      </div>
    </div>
  </section>

  <section class="bg-[#0D1524] py-14">
    <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <h2 class="text-2xl font-extrabold text-white">Ready to discuss your project?</h2>
        <p class="text-gray-400 text-sm mt-1">Get in touch — we'll give you a straight answer and an honest quote.</p>
      </div>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 bg-[#6ec4d0] text-gray-900 px-7 py-4 text-xs font-bold uppercase tracking-widest hover:bg-[#5aabb7] transition-colors rounded whitespace-nowrap"
      >
        GET A FREE QUOTE
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>

  <Footer />
</Layout>
